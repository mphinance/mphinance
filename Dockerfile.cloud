# ═══════════════════════════════════════════════════════════════
# Dockerfile.cloud — mphinance Pipeline Cloud Run Jobs
#
# Multi-stage build for running batch_scanner.py and
# dossier/generate.py as Cloud Run Jobs on GCP.
#
# Build:
#   docker build -f Dockerfile.cloud -t mphinance-pipeline .
#
# Run locally:
#   docker run --env-file secrets.env mphinance-pipeline python batch_scanner.py
#   docker run --env-file secrets.env mphinance-pipeline python -m dossier.generate
# ═══════════════════════════════════════════════════════════════

# ── Stage 1: Builder — install Python deps ──
FROM python:3.12-slim AS builder

# System deps for compilation (numpy, pandas, scikit-learn wheels)
RUN apt-get update && apt-get install -y --no-install-recommends \
    gcc g++ \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /build

# Install Python deps first (layer caching)
COPY requirements.txt requirements-cloud.txt ./
RUN pip install --no-cache-dir --prefix=/install \
    -r requirements.txt \
    -r requirements-cloud.txt


# ── Stage 2: Runtime — lean production image ──
FROM python:3.12-slim AS runtime

# System runtime deps (matplotlib needs fontconfig, mplfinance needs freetype)
RUN apt-get update && apt-get install -y --no-install-recommends \
    libfreetype6 \
    fontconfig \
    fonts-dejavu-core \
    && rm -rf /var/lib/apt/lists/* \
    && fc-cache -f

# Copy installed Python packages from builder
COPY --from=builder /install /usr/local

# Set up app directory
WORKDIR /app
ENV PYTHONPATH=/app \
    PYTHONUNBUFFERED=1 \
    MPLBACKEND=Agg

# Copy application code
# Order: least-changed first for better layer caching
COPY strategies/ strategies/
COPY dossier/ dossier/
COPY data/ data/
COPY templates/ templates/
COPY gcp/ gcp/

# Root-level scripts and modules
COPY batch_scanner.py scanner_logic.py stock_analyzer.py ./
COPY fundamental_metrics.py options_flow.py asbury_metrics.py ./
COPY cboe_weekly_scanner.py wheel_scanner_service.py ./

# Config and knowledge files (used by pipeline + Vertex AI training)
COPY VOICE.md CLAUDE.md WIKI.md ./
COPY requirements.txt requirements-cloud.txt ./
COPY watchlist.txt ./

# Create output directories
RUN mkdir -p docs/reports docs/charts docs/ticker \
    dossier/persistence/data \
    landing/data

# Default: run the dossier pipeline
CMD ["python", "-m", "dossier.generate", "--no-pdf"]
