# Discord Webhooks - Add multiple webhooks with WEBHOOK_ prefix
# The name after WEBHOOK_ becomes the display name in the UI
WEBHOOK_TRADING=https://discord.com/api/webhooks/your-webhook-id/your-webhook-token
WEBHOOK_RESEARCH=https://discord.com/api/webhooks/your-webhook-id/your-webhook-token

# Google Sheets Integration
# Deploy the Google Apps Script from wheel_scanner/google_sheets_script.js
# and paste the Web App URL here
GOOGLE_SHEETS_WEBHOOK=https://script.google.com/macros/s/your-script-id/exec
