//@version=6
indicator("Bounce 2.0 — mph1nance", overlay=true)

// --- EMA Stack ---
// Standard colors: 8=cyan, 21=yellow, 34=orange, 55=red, 89=purple
ema8  = ta.ema(close, 8)
ema21 = ta.ema(close, 21)
ema34 = ta.ema(close, 34)
ema55 = ta.ema(close, 55)
ema89 = ta.ema(close, 89)

plot(ema8,  title="EMA 8",  color=color.cyan,   linewidth=2)
plot(ema21, title="EMA 21", color=color.yellow, linewidth=2)
plot(ema34, title="EMA 34", color=color.orange, linewidth=2)
plot(ema55, title="EMA 55", color=color.red,    linewidth=2)
plot(ema89, title="EMA 89", color=color.purple, linewidth=2)

// Alignment Logic
full_bullish = (ema8 > ema21) and (ema21 > ema34) and (ema34 > ema55) and (ema55 > ema89)
partial_bullish = (ema8 > ema21) and (ema21 > ema55)
ema_aligned = full_bullish or partial_bullish

bgcolor(full_bullish ? color.new(color.green, 90) : na, title="Full Bullish Background")

// --- Technical Factors ---
// ADX(14) for Trend Strength
[diplus, diminus, adx] = ta.dmi(14, 14)
adx_strong = adx >= 25

// Stochastic K(14,3,3) for Pullback Detection
k = ta.sma(ta.stoch(close, high, low, 14), 3)
stoch_oversold = k <= 40

// RSI(14) Sweet Spot
rsi_val = ta.rsi(close, 14)
rsi_good = rsi_val >= 40 and rsi_val <= 65
rsi_hot = rsi_val > 70

// Price proximity to EMA 21
pct_from_ema21 = ((close - ema21) / ema21) * 100
price_near_support = (pct_from_ema21 >= -3) and (pct_from_ema21 <= 5)

// Relative Volume (10-period)
rel_vol = volume / ta.sma(volume, 10)

// --- Bounce 2.0 Signal ---
// The Core Signal: Aligned EMAs + Strong Trend + Oversold Pullback + Near Support
bounce2_signal = ema_aligned and adx_strong and stoch_oversold and price_near_support

// Visualization
plotshape(series=bounce2_signal, title="Bounce 2.0 Signal", location=location.belowbar, color=color.new(color.green, 0), style=shape.labelup, text="⚡ B2.0", textcolor=color.white, size=size.small)

// Alert Condition
alertcondition(bounce2_signal, title="Bounce 2.0 Signal Fired", message="⚡ Bounce 2.0 Setup Detected on {{ticker}}! EMA aligned, ADX strong, and Stoch oversold.")

// --- Dashboard Table ---
var table scoreTable = table.new(position.top_right, 2, 7, bgcolor=color.new(#0a0e27, 10), border_width=1, border_color=color.new(color.blue, 80))

if barstate.islast
    table.cell(scoreTable, 0, 0, "FACTOR", text_color=color.white, text_halign=text.align_left)
    table.cell(scoreTable, 1, 0, "STATUS", text_color=color.white, text_halign=text.align_center)
    
    table.cell(scoreTable, 0, 1, "EMA ALIGNED", text_color=color.white, text_halign=text.align_left)
    table.cell(scoreTable, 1, 1, ema_aligned ? "YES" : "NO", text_color=ema_aligned ? color.green : color.red)
    
    table.cell(scoreTable, 0, 2, "ADX (" + str.tostring(math.round(adx,1)) + ")", text_color=color.white, text_halign=text.align_left)
    table.cell(scoreTable, 1, 2, adx_strong ? "STRONG" : "WEAK", text_color=adx_strong ? color.green : color.gray)
    
    table.cell(scoreTable, 0, 3, "STOCH K (" + str.tostring(math.round(k,1)) + ")", text_color=color.white, text_halign=text.align_left)
    table.cell(scoreTable, 1, 3, stoch_oversold ? "OVERSOLD" : "NORMAL", text_color=stoch_oversold ? color.green : color.gray)
    
    table.cell(scoreTable, 0, 4, "RSI (" + str.tostring(math.round(rsi_val,1)) + ")", text_color=color.white, text_halign=text.align_left)
    table.cell(scoreTable, 1, 4, rsi_hot ? "HOT" : (rsi_good ? "SWEET" : "MID"), text_color=rsi_hot ? color.red : (rsi_good ? color.green : color.gray))
    
    table.cell(scoreTable, 0, 5, "PROXIMITY", text_color=color.white, text_halign=text.align_left)
    table.cell(scoreTable, 1, 5, price_near_support ? "NEAR" : "FAR", text_color=price_near_support ? color.green : color.gray)
    
    table.cell(scoreTable, 0, 6, "BOUNCE 2.0", text_color=color.white, text_halign=text.align_left)
    table.cell(scoreTable, 1, 6, bounce2_signal ? "⚡ READY" : "WAITING", text_color=bounce2_signal ? color.green : color.gray)
