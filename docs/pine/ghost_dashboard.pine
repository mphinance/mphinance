// Ghost × Gemini [mph1nance] — AI Trading Partner Feed
// © mph1nance + Sam the Quant Ghost
//
// PURPOSE: Dashboard-only indicator designed for Gemini in Chrome.
// Gemini reads the TradingView tab and uses this structured data
// to provide real-time trading analysis. No chart overlays — just
// the info panel + AI-readable data rows.
//
// USE: Add to any chart alongside your main indicator. Gemini sees
// the dashboard box and can answer: "What's the grade? Should I
// enter here? Where's my stop? What's the regime?"

//@version=6
indicator("Ghost × Gemini [mph1nance]", "👻×🤖", overlay=true, max_bars_back=500)

// ═══════════════════════════════════════════════════════════════
// ████  COLOR PALETTE — Synthwave Arcade  ████
// ═══════════════════════════════════════════════════════════════
const color C_BULL        = #00FFFF
const color C_BULL_SOFT   = #0088FF
const color C_BEAR        = #FF00FF
const color C_BEAR_DEEP   = #D500F9
const color C_NEUTRAL     = #9C27B0
const color C_SQUEEZE     = #FF00A0
const color C_WARNING     = #FFD740
const color C_BREAK       = #FF3D00
const color C_CONFLUENCE  = #00FFCC
const color C_DASH_BG     = #090014
const color C_DASH_BORDER = #FF00FF
const color C_DASH_TEXT   = #00FFFF

// ═══════════════════════════════════════════════════════════════
// ████  TIMEFRAME ENGINE  ████
// ═══════════════════════════════════════════════════════════════

float _tf_sec  = timeframe.in_seconds()
float _log_tf  = math.log(math.max(_tf_sec, 60))
float _log_5m  = math.log(300)
float _log_1d  = math.log(86400)
float _tf_pct  = math.max(0.0, math.min(1.0, (_log_tf - _log_5m) / (_log_1d - _log_5m)))

_lerp(float lo, float hi) => math.round(lo + _tf_pct * (hi - lo))

// ═══════════════════════════════════════════════════════════════
// ████  INPUTS  ████
// ═══════════════════════════════════════════════════════════════

adapt_group   = "━━━ 🔧 Settings ━━━"
auto_adapt    = input.bool(true, "Auto-adapt to timeframe", group=adapt_group)

dash_group  = "━━━ 📋 Dashboard ━━━"
dash_pos    = input.string("Top Right", "Position", options=["Top Right", "Top Left", "Bottom Right", "Bottom Left"], group=dash_group)
dash_size   = input.string("Small", "Text Size", options=["Tiny", "Small", "Normal"], group=dash_group)

hull_group      = "━━━ 🌊 Hull ━━━"
hull_src        = input.source(close, "Source", group=hull_group)
hull_mode       = input.string("Hma", "Variation", options=["Hma", "Ehma", "Thma"], group=hull_group)
hull_len_man    = input.int(55, "Length", group=hull_group)

trama_group   = "━━━ 🧠 TRAMA ━━━"
trama_len_man = input.int(34, "Length", group=trama_group)
trama_src     = input.source(close, "Source", group=trama_group)

kc_group      = "━━━ 📐 Keltner ━━━"
kc_len_man    = input.int(21, "EMA Length", group=kc_group)
kc_atr_man    = input.int(14, "ATR Length", group=kc_group)
kc_mult       = input.float(2.0, "ATR Mult", group=kc_group, step=0.1)

brk_group       = "━━━ 🏗️ Structure ━━━"
brk_swing_man   = input.int(5, "Swing Length", group=brk_group, minval=2, maxval=20)

exh_group       = "━━━ 💀 Exhaustion ━━━"
exh_fast_man    = input.int(21, "Fast %R", group=exh_group)
exh_slow_man    = input.int(112, "Slow %R", group=exh_group, minval=1)
exh_threshold   = input.int(20, "Threshold", group=exh_group, minval=1, maxval=50)
exh_fast_smooth = input.int(7, "Fast Smooth", group=exh_group, minval=1)
exh_slow_smooth = input.int(3, "Slow Smooth", group=exh_group, minval=1)

sqz_group   = "━━━ 🔋 Squeeze ━━━"
sqz_atr_len = input.int(14, "ATR Length", group=sqz_group)

iv_group    = "━━━ 📈 IV ━━━"
iv_hv_len   = input.int(21, "HV Length", group=iv_group, minval=5)
iv_rank_len = input.int(252, "Rank Lookback", group=iv_group, minval=50)

trail_group  = "━━━ 👻 Ghost Trail ━━━"
trail_atr    = input.int(14, "ATR Length", group=trail_group)
trail_mult   = input.float(2.5, "ATR Mult", group=trail_group, step=0.1)

// ═══════════════════════════════════════════════════════════════
// ████  ADAPTIVE PERIODS  ████
// ═══════════════════════════════════════════════════════════════

int hull_len     = auto_adapt ? _lerp(34, 89)   : hull_len_man
int trama_len    = auto_adapt ? _lerp(21, 55)   : trama_len_man
int exh_fast_len = auto_adapt ? _lerp(14, 21)   : exh_fast_man
int exh_slow_len = auto_adapt ? _lerp(55, 112)  : exh_slow_man
int brk_swing    = auto_adapt ? _lerp(3, 8)     : brk_swing_man

// ═══════════════════════════════════════════════════════════════
// ████  CALCULATIONS  ████
// ═══════════════════════════════════════════════════════════════

// ── Hull Band ────────────────────────────────────────────────
HMA(_s, _l)  => ta.wma(2 * ta.wma(_s, _l / 2) - ta.wma(_s, _l), math.round(math.sqrt(_l)))
EHMA(_s, _l) => ta.ema(2 * ta.ema(_s, _l / 2) - ta.ema(_s, _l), math.round(math.sqrt(_l)))
THMA(_s, _l) => ta.wma(ta.wma(_s, _l / 3) * 3 - ta.wma(_s, _l / 2) - ta.wma(_s, _l), _l)

_hull_calc(_s, _l, _mode) =>
    switch _mode
        "Hma"  => HMA(_s, _l)
        "Ehma" => EHMA(_s, _l)
        "Thma" => THMA(_s, _l / 2)

float hull_val = _hull_calc(hull_src, hull_len, hull_mode)
float MHULL    = hull_val
float SHULL    = hull_val[2]
bool  hull_bull = MHULL > SHULL
bool  hull_flip_bull = hull_bull and not hull_bull[1]
bool  hull_flip_bear = not hull_bull and hull_bull[1]

// ── TRAMA Regime ─────────────────────────────────────────────
float trama = 0.0
float t_hh  = math.max(math.sign(ta.change(ta.highest(high, trama_len))), 0.0)
float t_ll  = math.max(math.sign(ta.change(ta.lowest(low, trama_len)) * -1), 0.0)
float t_tc  = math.pow(ta.sma((t_hh != 0 or t_ll != 0) ? 1.0 : 0.0, trama_len), 2)
trama      := nz(trama[1] + t_tc * (trama_src - trama[1]), trama_src)

bool regime_strong   = t_tc > 0.25
bool regime_moderate = t_tc > 0.09
bool regime_bull     = trama > trama[1]
float trama_dist     = trama != 0 ? (close - trama) / trama * 100 : 0

// ── Keltner ──────────────────────────────────────────────────
float kc_basis = ta.ema(close, kc_len_man)
float kc_atr   = ta.atr(kc_atr_man)
float kc_upper = kc_basis + kc_atr * kc_mult
float kc_lower = kc_basis - kc_atr * kc_mult
bool  at_kc_lower = low <= kc_lower and close > kc_lower
bool  at_kc_upper = high >= kc_upper and close < kc_upper

// ── Key MAs ──────────────────────────────────────────────────
float sma_50     = ta.sma(close, 50)
float sma_200    = ta.sma(close, 200)
bool  above_50   = close > sma_50
bool  above_200  = close > sma_200
bool  golden_x   = sma_50 > sma_200

// ── Structure ────────────────────────────────────────────────
float sh = ta.pivothigh(high, brk_swing, brk_swing)
float sl = ta.pivotlow(low, brk_swing, brk_swing)
var float last_sh = na
var float last_sl = na
if not na(sh)
    last_sh := sh
if not na(sl)
    last_sl := sl

// ── RVOL ─────────────────────────────────────────────────────
float mkt_secs_day = syminfo.type == "crypto" ? 86400.0 : 23400.0
float bars_per_day = math.max(mkt_secs_day / _tf_sec, 1.0)
float rvol_baseline = ta.sma(volume, math.max(20, int(math.round(bars_per_day))))
float rvol       = nz(volume) > 0 and rvol_baseline > 0 ? volume / rvol_baseline : 0
bool  rvol_high  = rvol > 1.5
bool  rvol_surge = rvol > 2.5

bool brk_bear_raw = not na(last_sl) and close < last_sl and close[1] >= last_sl
bool brk_bull_raw = not na(last_sh) and close > last_sh and close[1] <= last_sh
bool brk_bear = brk_bear_raw and rvol > 1.0
bool brk_bull = brk_bull_raw and rvol > 1.0
bool brk_trap_bear = brk_bear_raw and rvol <= 1.0
bool brk_trap_bull = brk_bull_raw and rvol <= 1.0
bool sweep_bull = not na(last_sl) and low < last_sl and close >= last_sl
bool sweep_bear = not na(last_sh) and high > last_sh and close <= last_sh

// ── %R Exhaustion ────────────────────────────────────────────
_pr(int len) =>
    float mx = ta.highest(len)
    float mn = ta.lowest(len)
    100.0 * (close - mx) / (mx - mn)

float s_pctR = _pr(exh_fast_len)
float l_pctR = _pr(exh_slow_len)
if exh_fast_smooth > 1
    s_pctR := ta.ema(s_pctR, exh_fast_smooth)
if exh_slow_smooth > 1
    l_pctR := ta.ema(l_pctR, exh_slow_smooth)

bool exh_ob          = s_pctR >= -exh_threshold and l_pctR >= -exh_threshold
bool exh_os          = s_pctR <= (-100 + exh_threshold) and l_pctR <= (-100 + exh_threshold)
bool exh_bear_rev    = not exh_ob and exh_ob[1]
bool exh_bull_rev    = not exh_os and exh_os[1]

// ── Divergence ───────────────────────────────────────────────
int div_lookback = 5
float price_hi_now = ta.highest(high, div_lookback)
float price_hi_prev = ta.highest(high, div_lookback)[div_lookback]
float price_lo_now = ta.lowest(low, div_lookback)
float price_lo_prev = ta.lowest(low, div_lookback)[div_lookback]
float wr_hi_now = ta.highest(s_pctR, div_lookback)
float wr_hi_prev = ta.highest(s_pctR, div_lookback)[div_lookback]
float wr_lo_now = ta.lowest(s_pctR, div_lookback)
float wr_lo_prev = ta.lowest(s_pctR, div_lookback)[div_lookback]
bool div_bear = price_hi_now > price_hi_prev and wr_hi_now < wr_hi_prev and exh_ob
bool div_bull = price_lo_now < price_lo_prev and wr_lo_now > wr_lo_prev and exh_os

// ── Squeeze ──────────────────────────────────────────────────
float sqz_atr      = ta.atr(sqz_atr_len)
float sqz_baseline = ta.sma(sqz_atr, 50)
float sqz_ratio    = nz(sqz_baseline) > 0 ? sqz_atr / sqz_baseline : 1.0
bool  sqz_coiled    = sqz_ratio < 0.75
bool  sqz_fire      = sqz_ratio >= 0.75 and sqz_ratio[1] < 0.75

// ── IV ───────────────────────────────────────────────────────
float bar_ret      = math.log(close / close[1])
float hv           = ta.stdev(bar_ret, iv_hv_len) * math.sqrt(bars_per_day * 252) * 100
float hv_hi        = ta.highest(hv, iv_rank_len)
float hv_lo        = ta.lowest(hv, iv_rank_len)
float iv_pctile    = (hv_hi - hv_lo) != 0 ? (hv - hv_lo) / (hv_hi - hv_lo) * 100 : 50
bool  iv_low       = iv_pctile < 25
bool  iv_high      = iv_pctile > 75

// ── CVD / Shape ──────────────────────────────────────────────
float candle_range = high - low
float buy_pressure = candle_range != 0 ? (close - low) / candle_range : 0.5
float delta        = volume * (buy_pressure - (1.0 - buy_pressure))
float cvd          = ta.cum(delta)
float cvd_sma      = ta.sma(cvd, 20)
bool  cvd_bullish  = cvd > cvd_sma
bool  cvd_bearish  = cvd < cvd_sma

// ── CMF ──────────────────────────────────────────────────────
float cmf_mf   = candle_range != 0 ? ((close - low) - (high - close)) / candle_range : 0.0
float cmf_mfv  = cmf_mf * volume
float cmf      = ta.sma(volume, 20) != 0 ? ta.sma(cmf_mfv, 20) / ta.sma(volume, 20) : 0.0

// ── Confluence ───────────────────────────────────────────────
int bull_conf = 0
int bear_conf = 0
if exh_bull_rev
    bull_conf += 1
if exh_bear_rev
    bear_conf += 1
if brk_bull
    bull_conf += 1
if brk_bear
    bear_conf += 1
if sqz_fire and hull_bull
    bull_conf += 1
if sqz_fire and not hull_bull
    bear_conf += 1
if rvol_high and hull_bull and at_kc_lower
    bull_conf += 1
if rvol_high and not hull_bull and at_kc_upper
    bear_conf += 1
if hull_flip_bull
    bull_conf += 1
if hull_flip_bear
    bear_conf += 1
if sweep_bull
    bull_conf += 1
if sweep_bear
    bear_conf += 1
if cvd_bullish and hull_bull
    bull_conf += 1
if cvd_bearish and not hull_bull
    bear_conf += 1

bool mega_bull = bull_conf >= 2
bool mega_bear = bear_conf >= 2

// ── Trend Age ────────────────────────────────────────────────
var int trend_age = 0
if hull_bull == hull_bull[1]
    trend_age += 1
else
    trend_age := 0
string trend_phase = trend_age < 5 ? "FRESH" : trend_age < 20 ? "YOUNG" : trend_age < 50 ? "MATURE" : "AGING"

// ── Ghost Trail ──────────────────────────────────────────────
var float ghost_trail = na
float trail_atr_val   = ta.atr(trail_atr)
float long_stop  = ta.highest(high, trail_atr) - trail_atr_val * trail_mult
float short_stop = ta.lowest(low, trail_atr) + trail_atr_val * trail_mult
if hull_bull
    ghost_trail := hull_flip_bull ? long_stop : math.max(nz(ghost_trail[1], long_stop), long_stop)
else
    ghost_trail := hull_flip_bear ? short_stop : math.min(nz(ghost_trail[1], short_stop), short_stop)

bool trail_cross_bear = not na(ghost_trail) and close < ghost_trail and close[1] >= ghost_trail and hull_bull[1]
bool trail_cross_bull = not na(ghost_trail) and close > ghost_trail and close[1] <= ghost_trail and not hull_bull[1]

// ── Ghost Grade V2 ───────────────────────────────────────────
float ax1_trend  = hull_bull ? (regime_bull ? 1.0 : 0.5) : (not regime_bull ? 1.0 : 0.5)
float ax2_volume = cmf > 0.05 and hull_bull ? 1.0 : cmf < -0.05 and not hull_bull ? 1.0 : math.abs(cmf) > 0.05 ? 0.0 : 0.5
float ax3_vol = (sqz_ratio >= 0.75 and sqz_ratio <= 1.5) ? 1.0 : sqz_fire ? 1.0 : 0.0
float ax4_time = trend_age >= 5 and trend_age <= 30 ? 1.0 : trend_age > 30 and trend_age <= 50 ? 0.5 : 0.0
bool _no_exh = not exh_ob and not exh_os
float ax5_revert = (_no_exh and math.abs(trama_dist) < 3.0) ? 1.0 : _no_exh ? 0.5 : 0.0

float g_score = ax1_trend + ax2_volume + ax3_vol + ax4_time + ax5_revert
string ghost_grade = g_score >= 4.5 ? "A+" : g_score >= 4.0 ? "A" : g_score >= 3.0 ? "B" : g_score >= 2.0 ? "C" : g_score >= 1.0 ? "D" : "F"

// ═══════════════════════════════════════════════════════════════
// ████  DASHBOARD  ████
// ═══════════════════════════════════════════════════════════════

var tbl_pos = switch dash_pos
    "Top Right"    => position.top_right
    "Top Left"     => position.top_left
    "Bottom Right" => position.bottom_right
    => position.bottom_left
var tbl_size = switch dash_size
    "Tiny"   => size.tiny
    "Small"  => size.small
    => size.normal
var table tbl = na

if barstate.isfirst
    tbl := table.new(tbl_pos, 3, 25, bgcolor=C_DASH_BG, border_width=2, border_color=C_DASH_BORDER, frame_width=3, frame_color=C_DASH_BORDER)

if barstate.islast
    int row = 0

    // ── Header ───────────────────────────────────────────────
    table.cell(tbl, 0, row, "GHOST × GEMINI", text_color=C_DASH_TEXT, text_size=tbl_size, text_halign=text.align_center, bgcolor=color.new(C_DASH_BORDER, 70))
    table.merge_cells(tbl, 0, row, 2, row)
    row += 1

    // ── Regime ───────────────────────────────────────────────
    string r_text   = regime_strong ? (regime_bull ? "BULL ▲" : "BEAR ▼") : regime_moderate ? "MODERATE" : "CHOP ═"
    color  r_color  = regime_strong ? (regime_bull ? C_BULL : C_BEAR) : regime_moderate ? C_WARNING : C_NEUTRAL
    table.cell(tbl, 0, row, "REGIME",  text_color=color.new(C_DASH_TEXT, 40), text_size=tbl_size, text_halign=text.align_left)
    table.cell(tbl, 1, row, r_text,    text_color=r_color, text_size=tbl_size, text_halign=text.align_center)
    table.cell(tbl, 2, row, trend_phase, text_color=color.new(C_DASH_TEXT, 55), text_size=tbl_size, text_halign=text.align_right)
    row += 1

    // ── TRAMA ────────────────────────────────────────────────
    string td_text  = math.abs(trama_dist) < 1 ? "AT VALUE" : trama_dist > 0 ? "+" + str.tostring(math.round(trama_dist * 10) / 10) + "%" : str.tostring(math.round(trama_dist * 10) / 10) + "%"
    color  td_color = math.abs(trama_dist) < 1 ? C_CONFLUENCE : math.abs(trama_dist) > 3 ? C_WARNING : color.new(C_DASH_TEXT, 40)
    table.cell(tbl, 0, row, "TRAMA Δ", text_color=color.new(C_DASH_TEXT, 40), text_size=tbl_size, text_halign=text.align_left)
    table.cell(tbl, 1, row, td_text,   text_color=td_color, text_size=tbl_size, text_halign=text.align_center)
    table.cell(tbl, 2, row, str.tostring(math.round(t_tc * 100)) + "%", text_color=color.new(C_DASH_TEXT, 50), text_size=tbl_size, text_halign=text.align_right)
    row += 1

    // ── Squeeze ──────────────────────────────────────────────
    string sq_text   = sqz_fire ? "RELEASE ⚡" : sqz_coiled ? "COILED ◉" : "NORMAL"
    color  sq_color  = sqz_fire ? C_WARNING : sqz_coiled ? C_SQUEEZE : color.new(C_DASH_TEXT, 50)
    table.cell(tbl, 0, row, "SQUEEZE", text_color=color.new(C_DASH_TEXT, 40), text_size=tbl_size, text_halign=text.align_left)
    table.cell(tbl, 1, row, sq_text,   text_color=sq_color, text_size=tbl_size, text_halign=text.align_center)
    table.cell(tbl, 2, row, str.tostring(math.round(sqz_ratio * 100) / 100), text_color=color.new(C_DASH_TEXT, 50), text_size=tbl_size, text_halign=text.align_right)
    row += 1

    // ── Exhaustion ───────────────────────────────────────────
    string e_text  = exh_bear_rev ? "EXIT ▼" : exh_bull_rev ? "EXIT ▲" : exh_ob ? "OVERBOUGHT" : exh_os ? "OVERSOLD" : "CLEAR"
    color  e_color = (exh_bear_rev or exh_ob) ? C_BEAR : (exh_bull_rev or exh_os) ? C_BULL : color.new(C_DASH_TEXT, 50)
    table.cell(tbl, 0, row, "EXHAUST", text_color=color.new(C_DASH_TEXT, 40), text_size=tbl_size, text_halign=text.align_left)
    table.cell(tbl, 1, row, e_text,    text_color=e_color, text_size=tbl_size, text_halign=text.align_center)
    table.cell(tbl, 2, row, str.tostring(math.round(s_pctR)), text_color=color.new(C_DASH_TEXT, 50), text_size=tbl_size, text_halign=text.align_right)
    row += 1

    // ── Structure ────────────────────────────────────────────
    string brk_text  = brk_bear ? "BROKEN ▼" : brk_bull ? "BROKEN ▲" : brk_trap_bear ? "TRAP ▼" : brk_trap_bull ? "TRAP ▲" : "INTACT"
    color  brk_color = (brk_bear or brk_bull) ? C_BREAK : (brk_trap_bear or brk_trap_bull) ? C_WARNING : color.new(C_DASH_TEXT, 50)
    table.cell(tbl, 0, row, "STRUCT", text_color=color.new(C_DASH_TEXT, 40), text_size=tbl_size, text_halign=text.align_left)
    table.cell(tbl, 1, row, brk_text,  text_color=brk_color, text_size=tbl_size, text_halign=text.align_center)
    table.cell(tbl, 2, row, not na(last_sl) ? str.tostring(last_sl, format.mintick) : "—", text_color=color.new(C_DASH_TEXT, 50), text_size=tbl_size, text_halign=text.align_right)
    row += 1

    // ── Keltner ──────────────────────────────────────────────
    string kc_text  = at_kc_lower ? "LOWER ▽" : at_kc_upper ? "UPPER △" : "INSIDE"
    color  kc_color = at_kc_lower ? C_BULL : at_kc_upper ? C_BEAR : color.new(C_DASH_TEXT, 50)
    table.cell(tbl, 0, row, "KELT", text_color=color.new(C_DASH_TEXT, 40), text_size=tbl_size, text_halign=text.align_left)
    table.cell(tbl, 1, row, kc_text, text_color=kc_color, text_size=tbl_size, text_halign=text.align_center)
    string ma_status = golden_x ? "50>200 ✓" : "50<200 ✗"
    table.cell(tbl, 2, row, ma_status, text_color=golden_x ? color.new(C_BULL, 40) : color.new(C_BEAR, 40), text_size=tbl_size, text_halign=text.align_right)
    row += 1

    // ── IV/VOL ───────────────────────────────────────────────
    string iv_text  = iv_low ? "LOW 🔋" : iv_high ? "HIGH 🔥" : "MID"
    color  iv_color = iv_low ? C_SQUEEZE : iv_high ? C_WARNING : color.new(C_DASH_TEXT, 50)
    table.cell(tbl, 0, row, "IV/VOL", text_color=color.new(C_DASH_TEXT, 40), text_size=tbl_size, text_halign=text.align_left)
    table.cell(tbl, 1, row, iv_text,   text_color=iv_color, text_size=tbl_size, text_halign=text.align_center)
    string rv_text  = rvol_surge ? "⚡" + str.tostring(math.round(rvol * 10) / 10) + "x" : str.tostring(math.round(rvol * 10) / 10) + "x"
    table.cell(tbl, 2, row, rv_text, text_color=rvol_surge ? C_WARNING : rvol_high ? C_BULL_SOFT : color.new(C_DASH_TEXT, 50), text_size=tbl_size, text_halign=text.align_right)
    row += 1

    // ── Delta ────────────────────────────────────────────────
    string cvd_text  = cvd_bullish ? "BUYERS ▲" : "SELLERS ▼"
    color  cvd_color = cvd_bullish ? C_BULL : C_BEAR
    bool   cvd_diverge = ((cvd_bullish and not hull_bull) or (cvd_bearish and hull_bull)) and (regime_strong or regime_moderate)
    table.cell(tbl, 0, row, "DELTA", text_color=color.new(C_DASH_TEXT, 40), text_size=tbl_size, text_halign=text.align_left)
    table.cell(tbl, 1, row, cvd_text, text_color=cvd_color, text_size=tbl_size, text_halign=text.align_center)
    table.cell(tbl, 2, row, cvd_diverge ? "⚠ DIV" : "", text_color=cvd_diverge ? C_WARNING : color.new(C_DASH_TEXT, 50), text_size=tbl_size, text_halign=text.align_right)
    row += 1

    // ── Adapt ────────────────────────────────────────────────
    table.cell(tbl, 0, row, "ADAPT", text_color=color.new(C_DASH_TEXT, 40), text_size=tbl_size, text_halign=text.align_left)
    table.cell(tbl, 1, row, "H" + str.tostring(hull_len) + " T" + str.tostring(trama_len), text_color=color.new(C_DASH_TEXT, 60), text_size=tbl_size, text_halign=text.align_center)
    table.cell(tbl, 2, row, "R" + str.tostring(exh_fast_len) + "/" + str.tostring(exh_slow_len), text_color=color.new(C_DASH_TEXT, 60), text_size=tbl_size, text_halign=text.align_right)
    row += 1

    // ── Grade V2 ─────────────────────────────────────────────
    color g_color = ghost_grade == "A+" ? C_CONFLUENCE : ghost_grade == "A" ? C_BULL : ghost_grade == "B" ? C_BULL_SOFT : ghost_grade == "C" ? C_WARNING : ghost_grade == "D" ? C_BEAR : C_BEAR_DEEP
    string dir_text  = hull_bull ? "LONG ▲" : "SHORT ▼"
    color  dir_color = hull_bull ? C_BULL : C_BEAR
    table.cell(tbl, 0, row, "GRADE", text_color=color.new(C_DASH_TEXT, 40), text_size=tbl_size, text_halign=text.align_left)
    table.cell(tbl, 1, row, ghost_grade + " (" + str.tostring(math.round(g_score * 10) / 10) + "/5)", text_color=g_color, text_size=tbl_size, text_halign=text.align_center)
    table.cell(tbl, 2, row, dir_text, text_color=dir_color, text_size=tbl_size, text_halign=text.align_right)
    row += 1

    // ═════════════════════════════════════════════════════════
    // GEMINI AI FEED — structured data for AI context
    // Gemini reads this section to understand the full picture
    // ═════════════════════════════════════════════════════════
    table.cell(tbl, 0, row, "AI CONTEXT", text_color=C_DASH_TEXT, text_size=size.tiny, text_halign=text.align_center, bgcolor=color.new(#00FFCC, 80))
    table.merge_cells(tbl, 0, row, 2, row)
    row += 1

    // Price levels — support, resistance, stop
    table.cell(tbl, 0, row, "STOP", text_color=color.new(C_DASH_TEXT, 50), text_size=size.tiny, text_halign=text.align_left)
    table.cell(tbl, 1, row, str.tostring(ghost_trail, format.mintick), text_color=hull_bull ? color.new(C_BULL, 40) : color.new(C_BEAR, 40), text_size=size.tiny, text_halign=text.align_center)
    float stop_pct = close != 0 ? math.abs(close - ghost_trail) / close * 100 : 0
    table.cell(tbl, 2, row, str.tostring(math.round(stop_pct * 10) / 10) + "%", text_color=color.new(C_DASH_TEXT, 50), text_size=size.tiny, text_halign=text.align_right)
    row += 1

    // Key levels
    table.cell(tbl, 0, row, "S/R", text_color=color.new(C_DASH_TEXT, 50), text_size=size.tiny, text_halign=text.align_left)
    table.cell(tbl, 1, row, not na(last_sl) ? str.tostring(last_sl, format.mintick) : "—", text_color=color.new(C_BULL, 50), text_size=size.tiny, text_halign=text.align_center)
    table.cell(tbl, 2, row, not na(last_sh) ? str.tostring(last_sh, format.mintick) : "—", text_color=color.new(C_BEAR, 50), text_size=size.tiny, text_halign=text.align_right)
    row += 1

    // MAs for context
    table.cell(tbl, 0, row, "MAs", text_color=color.new(C_DASH_TEXT, 50), text_size=size.tiny, text_halign=text.align_left)
    table.cell(tbl, 1, row, "50:" + str.tostring(sma_50, format.mintick), text_color=above_50 ? color.new(C_BULL, 50) : color.new(C_BEAR, 50), text_size=size.tiny, text_halign=text.align_center)
    table.cell(tbl, 2, row, "200:" + str.tostring(sma_200, format.mintick), text_color=above_200 ? color.new(C_BULL, 50) : color.new(C_BEAR, 50), text_size=size.tiny, text_halign=text.align_right)
    row += 1

    // Active signals — what's firing RIGHT NOW
    string sig_now = ""
    if brk_bear or brk_bull
        sig_now += "BRK "
    if exh_bear_rev or exh_bull_rev
        sig_now += "EXH "
    if sweep_bear or sweep_bull
        sig_now += "SWP "
    if sqz_fire
        sig_now += "SQZ "
    if div_bear or div_bull
        sig_now += "DIV "
    if trail_cross_bear or trail_cross_bull
        sig_now += "TRL "
    if mega_bull or mega_bear
        sig_now += "👻 "
    if sig_now == ""
        sig_now := "NONE"
    string sig_dir = bull_conf > bear_conf ? "BULL" : bear_conf > bull_conf ? "BEAR" : "—"
    table.cell(tbl, 0, row, "SIGS", text_color=color.new(C_DASH_TEXT, 50), text_size=size.tiny, text_halign=text.align_left)
    table.cell(tbl, 1, row, sig_now, text_color=mega_bull ? C_CONFLUENCE : mega_bear ? C_BEAR : color.new(C_DASH_TEXT, 40), text_size=size.tiny, text_halign=text.align_center)
    table.cell(tbl, 2, row, sig_dir, text_color=color.new(C_DASH_TEXT, 50), text_size=size.tiny, text_halign=text.align_right)
    row += 1

    // Risk sizing
    float risk_dollars = 100.0
    float shares_size  = trail_atr_val > 0 ? math.floor(risk_dollars / trail_atr_val) : 0
    table.cell(tbl, 0, row, "RISK", text_color=color.new(C_DASH_TEXT, 50), text_size=size.tiny, text_halign=text.align_left)
    table.cell(tbl, 1, row, str.tostring(shares_size) + " sh", text_color=color.new(C_DASH_TEXT, 40), text_size=size.tiny, text_halign=text.align_center)
    table.cell(tbl, 2, row, "$" + str.tostring(math.round(trail_atr_val * 100) / 100) + " ATR", text_color=color.new(C_DASH_TEXT, 50), text_size=size.tiny, text_halign=text.align_right)
    row += 1

    // Compressed AI payload (for OCR / screenshot parsing)
    string ai_payload = syminfo.ticker + "|" + timeframe.period + "|" + ghost_grade + "|" + (hull_bull ? "LONG" : "SHORT") + "|" + r_text + "|" + str.tostring(close) + "|" + str.tostring(ghost_trail, format.mintick) + "|" + str.tostring(math.round(rvol * 10) / 10) + "x|" + (sqz_fire ? "FIRE" : sqz_coiled ? "COIL" : "NORM") + "|" + str.tostring(math.round(trama_dist * 10) / 10) + "%" + "|" + sig_now
    table.merge_cells(tbl, 0, row, 2, row)
    table.cell(tbl, 0, row, ai_payload, text_color=color.new(C_DASH_TEXT, 75), text_size=size.tiny, text_halign=text.align_center)
