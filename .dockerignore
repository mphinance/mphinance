# ── Docker build exclusions ──
# Keep the image lean — exclude dev artifacts, git, venvs

.git
.github
.vscode
__pycache__
*.pyc
venv/
.env
secrets.env
service_account.json

# Large files not needed in pipeline
docs/
landing/
*.pine
main.py

# Substack tools (not part of pipeline)
substack_*.py

# Dev task files
TASKS.md
TASK_*.md
TODO.md
GHOST_HANDOFF.md
MOMENTUM_SQUEEZE_GUIDE.md
STOCK_ANALYZER_README.md
BATCH_SCANNER_README.md
README.md

# Capture tool (NiceGUI, not cloud)
capture.py
