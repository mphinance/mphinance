# ─── Secrets (NEVER commit) ────────────────────────────────
.env
.env.*
secrets.env
service_account.json
vaultguard/service_account.json
gcp/secrets.py

# ─── Python ────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
venv/
.venv/
*.egg-info/
dist/
build/

# ─── IDE ───────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ─── OS ────────────────────────────────────────────────────
.DS_Store
Thumbs.db

